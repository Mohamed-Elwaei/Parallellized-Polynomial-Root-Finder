# Build directories
build/
cmake-build*/
out/

# Editor / OS cruft
.vscode/
.idea/
*.o
*.obj
*.exe
.DS_Store

# CTest run artifacts (regenerated under build/)
Testing/

# Claude Code local tooling (preview launch config, session state)
.claude/

# Python bytecode (from the GUI)
__pycache__/
*.pyc

# LaTeX build artifacts (paper/ is compiled from paper.tex via tectonic/pdflatex)
paper/*.pdf
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
